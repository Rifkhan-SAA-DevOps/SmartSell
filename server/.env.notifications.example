# SmartSell notification channels
# Keep false until your SMTP/WhatsApp details are ready.
CLIENT_URL=http://localhost:5174
BRAND_NAME=SmartSell

# Email SMTP notification settings
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SmartSell <your-email@gmail.com>"

# WhatsApp notification settings
# For real automatic WhatsApp messages, connect this to your WhatsApp Business/Twilio/webhook provider.
NOTIFY_WHATSAPP_ENABLED=false
WHATSAPP_WEBHOOK_URL=
WHATSAPP_BEARER_TOKEN=
WHATSAPP_FROM=SmartSell
